<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.solvd.hospital.dao.AppointmentDao">

    <!-- ==================== ResultMap ==================== -->

    <resultMap id="appointmentResultMap" type="Appointment">
        <id     property="id"          column="id"/>
        <result property="patientID"   column="patients_id"/>
        <result property="scheduledAt" column="scheduled_at"/>
        <result property="status"      column="status"/>
        <result property="notes"       column="notes"/>
        <association property="doctor" javaType="Doctor">
            <id property="id" column="doctors_id"/>
        </association>
    </resultMap>

    <!-- ==================== INSERT ==================== -->

    <insert id="create" parameterType="Appointment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO appointments (scheduled_at, status, notes, doctors_id, patients_id)
        VALUES (#{scheduledAt}, #{status}, #{notes}, #{doctor.id}, #{patientID})
    </insert>

    <!-- ==================== UPDATE ==================== -->
    <update id="update" parameterType="Appointment">
        UPDATE appointments
        SET scheduled_at = #{scheduledAt},
        status       = #{status},
        notes        = #{notes}
        WHERE id = #{id}
    </update>

    <!-- ==================== DELETE ==================== -->
    <delete id="delete" parameterType="long">
        DELETE FROM appointments WHERE id = #{id}
    </delete>

    <!-- ==================== SELECT ==================== -->
    <select id="findById" parameterType="long" resultMap="appointmentResultMap">
        SELECT * FROM appointments WHERE id = #{id}
    </select>

    <select id="findByPatientId" parameterType="long" resultMap="appointmentResultMap">
        SELECT * FROM appointments WHERE patients_id = #{patientId}
    </select>

    <select id="findByDoctorId" parameterType="long" resultMap="appointmentResultMap">
        SELECT * FROM appointments WHERE doctors_id = #{doctorId}
    </select>

</mapper>