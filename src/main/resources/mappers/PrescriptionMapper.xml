<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.solvd.hospital.dao.PrescriptionDao">

    <!-- ==================== ResultMap ==================== -->
    <resultMap id="prescriptionResultMap" type="Prescription">
        <id     property="id"           column="id"/>
        <result property="issuedDate"   column="issued_date"/>
        <result property="instructions" column="instructions"/>

        <collection property="medications"
                    ofType="PrescriptionMedication"
                    select="selectMedicationsByPrescriptionId"
                    column="id"/>
    </resultMap>

    <resultMap id="medicationResultMap" type="PrescriptionMedication">
        <id     property="id"        column="id"/>
        <result property="name"      column="medication_name"/>
        <result property="dosage"    column="dosage"/>
        <result property="frequency" column="frequency"/>
    </resultMap>

    <!-- helper select used by the collection above -->
    <select id="selectMedicationsByPrescriptionId"
            parameterType="long"
            resultMap="medicationResultMap">
        SELECT * FROM prescription_medications WHERE prescriptions_id = #{value}
    </select>

    <!-- ==================== INSERT ==================== -->
    <insert id="create" parameterType="map" useGeneratedKeys="true" keyProperty="prescription.id">
        INSERT INTO prescriptions (issued_date, instructions, doctors_id, patients_id)
        VALUES (
        #{prescription.issuedDate},
        #{prescription.instructions},
        #{doctorId},
        #{patientId}
        )
    </insert>

    <!-- ==================== UPDATE ==================== -->
    <update id="update" parameterType="Prescription">
        UPDATE prescriptions
        SET issued_date   = #{issuedDate},
        instructions  = #{instructions}
        WHERE id = #{id}
    </update>

    <!-- ==================== DELETE ==================== -->
    <delete id="delete" parameterType="long">
        DELETE FROM prescriptions WHERE id = #{id}
    </delete>

    <!-- ==================== SELECT ==================== -->
    <select id="findById" parameterType="long" resultMap="prescriptionResultMap">
        SELECT * FROM prescriptions WHERE id = #{id}
    </select>

    <select id="findByPatientId" parameterType="long" resultMap="prescriptionResultMap">
        SELECT * FROM prescriptions WHERE patients_id = #{patientId}
    </select>

</mapper>