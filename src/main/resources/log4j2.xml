<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <!-- ==================== Console Appender ==================== -->
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %highlight{%-5level} %cyan{%c{1}} [%t] %msg%n"/>
        </Console>

        <!-- ==================== File Appender ==================== -->
        <File name="File" fileName="logs/app.log" append="true">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} %-5level %c{36} [%t] - %msg%n"/>
        </File>
    </Appenders>

    <!-- ==================== Root Logger ==================== -->
    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>
    </Loggers>

</Configuration>

        <!--
           Hierarchy
             ERROR
             WARN
             INFO
             DEBUG
             TRACE
             -->